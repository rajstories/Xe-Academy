# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Clerk authentication.
# VITE_CLERK_PUBLISHABLE_KEY is required by the React app.
# CLERK_SECRET_KEY is required by /api/clerk/update-metadata to write user.publicMetadata.
VITE_CLERK_PUBLISHABLE_KEY="pk_test_your_publishable_key"
CLERK_SECRET_KEY="sk_test_your_secret_key"

# White-labeled video uploads (YouTube Data API, server-side only).
# Used by /api/youtube/create-upload to start a resumable upload on your channel.
# 1. Create a Google Cloud project and enable the "YouTube Data API v3".
# 2. Create an OAuth 2.0 Client ID (Web application).
# 3. Generate a refresh token for the channel owner with scope:
#    https://www.googleapis.com/auth/youtube.upload
# Note: default quota allows ~6 uploads/day until you request an increase.
YT_CLIENT_ID="your_google_oauth_client_id"
YT_CLIENT_SECRET="your_google_oauth_client_secret"
YT_REFRESH_TOKEN="your_channel_refresh_token"

# Shared course catalog + enrollments (Upstash Redis, via a Vercel KV /
# Upstash Marketplace integration). Used by /api/courses/*.
# In Vercel: Storage tab -> connect a KV/Redis store to this project ->
# these two get added automatically. Without them, the catalog falls back
# to an empty list and enrollments aren't saved server-side.
KV_REST_API_URL="https://your-store.upstash.io"
KV_REST_API_TOKEN="your_upstash_rest_token"
